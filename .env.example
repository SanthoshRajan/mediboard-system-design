# ============================================================
# Application
# ============================================================
APP_NAME=Mediboard
APP_ENV=local
APP_KEY=base64:GENERATE_USING_ARTISAN
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost
REACT_FRONTEND_URL=http://localhost

APP_TIMEZONE=UTC
DISPLAY_TIMEZONE=Asia/Kolkata
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# ============================================================
# Logging
# ============================================================
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=debug
LOG_DAILY_DAYS=30

# ============================================================
# Database (Common + Tenant)
# ============================================================
DB_CONNECTION=mysql_client
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mediboard_common
DB_USERNAME=root
DB_PASSWORD=secret

# Admin connection (used for tenant DB creation)
DB_ADMIN_HOST=127.0.0.1
DB_ADMIN_PORT=3306
DB_ADMIN_DATABASE=mysql
DB_ADMIN_USERNAME=root
DB_ADMIN_PASSWORD=secret

# ============================================================
# Cache / Redis
# ============================================================
CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_PREFIX=mediboard_

REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2

# Cache TTL (important for services)
REDIS_TTL_STANDARD=1296000   # 15 days
REDIS_TTL_SESSION=86400      # 1 day

# ============================================================
# Queue
# ============================================================
QUEUE_CONNECTION=sync
TENANT_QUEUE=tenants
WHATSAPP_QUEUE=whatsapp

# ============================================================
# Session
# ============================================================
SESSION_DRIVER=redis
SESSION_CONNECTION=session
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ============================================================
# Filesystem / Storage
# ============================================================
FILESYSTEM_DISK=tenant_storage
TENANT_STORAGE_PATH=/storage

# Optional: switch to S3 in production
FILESYSTEM_CLOUD=s3

# ============================================================
# Mail
# ============================================================
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null

MAIL_FROM_ADDRESS="noreply@mediboard.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# AWS / S3 (Optional)
# ============================================================
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=your-bucket-name
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================
# CloudFront (Optional - for signed URLs)
# ============================================================
CLOUDFRONT_DOMAIN=your-distribution.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=YOUR_KEY_PAIR_ID
CLOUDFRONT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY\n-----END RSA PRIVATE KEY-----"
CLOUDFRONT_EXPIRY=30

# ============================================================
# JWT / Auth
# ============================================================
JWT_SECRET=GENERATE_RANDOM_SECRET
JWT_TTL=720

AUTH_GUARD=web
AUTH_PASSWORD_TIMEOUT=10800

# ============================================================
# Feature Flags
# ============================================================
REPORT_QR_CODE=false
REPORT_ABNORMAL_DETECTION=true

# Report styling
REPORT_BORDER=false
REPORT_CELL_BORDER=false

# ============================================================
# Security / Hashing
# ============================================================
BCRYPT_ROUNDS=12

# ============================================================
# WhatsApp Integration (Optional)
# ============================================================
WHATSAPP_PROVIDER=gupshup   # or twilio / wati / meta
WHATSAPP_URL=https://api.provider.com/send
WHATSAPP_API_KEY=YOUR_API_KEY
WHATSAPP_API_SECRET=YOUR_SECRET
WHATSAPP_FROM=YOUR_NUMBER

# ============================================================
# Observability (Optional)
# ============================================================
TELESCOPE_ENABLED=false
SENTRY_LARAVEL_DSN=

# ============================================================
# Python Integration (IMPORTANT)
# ============================================================
PYTHON_BINARY=python3
PYTHON_SCRIPT_PATH=/var/www/mediboard/app/PythonScripts/generate_report.py

# ============================================================
# Environment Notes
# ============================================================
# LOCAL:
#   APP_DEBUG=true
#   QUEUE_CONNECTION=sync
#   SESSION_SECURE_COOKIE=false
#
# PRODUCTION:
#   APP_DEBUG=false
#   QUEUE_CONNECTION=redis
#   SESSION_SECURE_COOKIE=true
#   LOG_LEVEL=warning
#   MAIL_MAILER=smtp